# RAG System Configuration
# Copy to ~/.rag/config.yaml and adjust as needed.

# Paths to watch for changes (fswatch)
# Only paths under $HOME are supported. Use ~ for home directory.
watch_paths:
  - ~/Developer
  - ~/.claude/projects

# Embedding model. Set to "auto" to pick based on system RAM:
#   32GB+: qwen3-embedding:8b
#   8-31GB: mxbai-embed-large
# Or set a specific model name to override.
embedding_model: auto

# Data paths (created automatically at defaults shown below)
# db_path: ~/.rag/chromadb
# queue_path: ~/.rag/queue.db
# audit_path: ~/.rag/audit.db
